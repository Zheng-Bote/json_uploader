{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/json_uploader-schema-v1.json",
  "title": "ExampleObject",
  "type": "object",
  "required": ["schema_version", "id", "name", "active", "tags", "metadata"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "number"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "active": {
      "type": "boolean"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object",
      "required": ["created", "owner"],
      "properties": {
        "created": {
          "type": "string",
          "format": "date-time"
        },
        "owner": {
          "type": "string"
        }
      }
    }
  }
}
